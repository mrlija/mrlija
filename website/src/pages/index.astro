---
import { CV_DATA } from "../data/cv";
import Layout from "../layouts/Layout.astro";
import CommandMenu from "../components/CommandMenu.astro";
import Header from "../components/Header.astro";
import Summary from "../components/Summary.astro";
import WorkExperience from "../components/WorkExperience.astro";
import Education from "../components/Education.astro";
import Skills from "../components/Skills.astro";
import Projects from "../components/Projects.astro";
import PrintResume from "../components/PrintResume.astro";

const { name, about, contact, location } = CV_DATA;

const websiteLink = contact.links.find((link) => link.kind === "website");
const emailLink = contact.links.find((link) => link.kind === "email");
const socialLinks = contact.links.filter((link) => link.kind === "social");

const personStructuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name,
  description: about,
  url: websiteLink?.url,
  email: emailLink?.url,
  sameAs: [websiteLink?.url, ...socialLinks.map((social) => social.url)].filter(
    Boolean,
  ),
  address: {
    "@type": "PostalAddress",
    addressLocality: location,
    addressCountry: "CZ",
  },
};
---

<Layout
  title={`${name}`}
  description={about}
  structuredData={personStructuredData}
>
  <CommandMenu />
  <main class="page-frame print:hidden" id="main-content">
    <section class="page-grid" aria-label="Obsah životopisu">
      <Header />
      <div class="rail-panel px-5 py-6 sm:px-7 sm:py-7">
        <Summary />
        <WorkExperience />
        <Projects />
        <Education />
        <Skills />
      </div>
    </section>
  </main>
  <PrintResume />
</Layout>
