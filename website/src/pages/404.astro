---
import Layout from "../layouts/Layout.astro";
import ArrowLeft from "../components/icons/ArrowLeft.astro";
---

<Layout
  title="404 - Stránka nenalezena"
  description="Stránka, kterou hledáte, neexistuje nebo byla přesunuta."
>
  <main class="page-frame flex min-h-screen items-center justify-center">
    <section class="rail-panel w-full max-w-xl p-6 sm:p-8">
      <article role="article">
        <p class="text-sm text-muted-foreground">404</p>
        <h1 class="mt-3 text-2xl font-semibold text-foreground">
          Stránka nenalezena
        </h1>
        <p class="mt-3 max-w-lg text-sm leading-7 text-muted-foreground">
          Stránka, kterou hledáte, neexistuje nebo byla přesunuta.
        </p>
        <div class="mt-6">
          <a class="plain-button gap-2" href="/">
            <ArrowLeft class="size-4" />
            Zpět na hlavní stránku
          </a>
        </div>
      </article>
    </section>
  </main>
</Layout>
