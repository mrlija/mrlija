---
import Badge from "./Badge.astro";

interface Props {
  title: string;
  description: string;
  link?: string;
  start?: string;
  end?: string | null;
  badges?: string[];
}

const { title, description, link, start, end, badges } = Astro.props;
const hasValidLink = link && link.trim().length > 0;
---

<article class="mt-2" role="article">
  <div class="item-row">
    <div>
      <div class="flex items-start justify-between gap-4">
        <h3 class="item-title pr-3">
          {
            hasValidLink ? (
              <a
                class="transition-colors duration-150 ease-out hover:text-primary"
                href={link}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Otevřít odkaz: ${title}`}
              >
                {title}
              </a>
            ) : (
              <span>{title}</span>
            )
          }
        </h3>
        {
          (start || end) && (
            <div
              class="item-meta shrink-0 text-right"
              aria-label={`Období: ${start ?? ""} až ${end ?? "Současnost"}`}
            >
              {start} {start && (end || end === null) && "-"}{" "}
              {end ?? (start ? "Současnost" : "")}
            </div>
          )
        }
      </div>
      <div class="item-description">
        {description}
      </div>
      {
        badges && badges.length > 0 && (
          <div class="tag-list">
            <ul
              class="flex list-none flex-wrap gap-2 p-0"
              aria-label="Použité technologie"
            >
              {badges.map((badge) => (
                <li>
                  <Badge variant="secondary">{badge}</Badge>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
  </div>
</article>
