---
import { CV_DATA } from "../data/cv";
import LinkedIn from "./icons/LinkedIn.astro";
import GitHub from "./icons/GitHub.astro";
import Email from "./icons/Email.astro";
import Globe from "./icons/Globe.astro";

import { Image } from "astro:assets";
import avatarImage from "../assets/avatar.jpeg";

const { name, contact, location, locationLink } = CV_DATA;

const getDisplayUrl = (url: string, kind: string) => {
  if (kind === "email") {
    return url.replace("mailto:", "");
  }

  return url.replace("https://", "");
};

const getSocialIconKey = (url: string): "github" | "linkedin" | "globe" => {
  try {
    const host = new URL(url).hostname.toLowerCase();
    if (host.includes("github")) {
      return "github";
    }
    if (host.includes("linkedin")) {
      return "linkedin";
    }
  } catch {}

  return "globe";
};

const getIconType = (
  url: string,
  kind: string,
): "email" | "github" | "linkedin" | "globe" => {
  if (kind === "email") {
    return "email";
  }

  return getSocialIconKey(url);
};
---

<header class="w-full lg:sticky lg:top-8 lg:self-start">
  <div class="rail-panel w-full overflow-hidden lg:mx-auto lg:max-w-xs">
    <div class="flex flex-col items-center p-5 text-center sm:p-6">
      <div class="flex w-full max-w-[13rem] flex-col items-center">
        <span
          class="relative flex aspect-square w-full shrink-0 overflow-hidden border border-border bg-secondary"
          style="border-radius: 12px"
          aria-hidden="true"
        >
          <Image
            class="aspect-square h-full w-full object-cover"
            alt={`${name}'s profile picture`}
            src={avatarImage}
          />
        </span>
        <div class="mt-4 w-full min-w-0">
          <h1
            class="text-3xl font-semibold tracking-tight text-foreground"
            id="cv-name"
          >
            {name}
          </h1>
          <a
            class="mt-3 inline-flex items-center justify-center gap-2 text-sm text-muted-foreground transition-colors duration-150 ease-out hover:text-foreground"
            href={locationLink}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Lokace: ${location}`}
          >
            <span>{location}</span>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-border">
      {
        contact.links.map((link) => (
          <a
            class="contact-link"
            href={link.url}
            target={link.kind === "email" ? undefined : "_blank"}
            rel={link.kind === "email" ? undefined : "noopener noreferrer"}
            aria-label={
              link.kind === "social" ? `${link.name} profil` : link.name
            }
          >
            {getIconType(link.url, link.kind) === "email" ? (
              <Email class="size-4" />
            ) : getIconType(link.url, link.kind) === "github" ? (
              <GitHub class="size-4" />
            ) : getIconType(link.url, link.kind) === "linkedin" ? (
              <LinkedIn class="size-4" />
            ) : (
              <Globe class="size-4" />
            )}
            <span class="min-w-0 truncate">
              {getDisplayUrl(link.url, link.kind)}
            </span>
          </a>
        ))
      }
    </div>

    <div
      class="hidden border-t border-border p-5 text-sm text-muted-foreground"
    >
      {
        contact.links.map((link) => (
          <p class="mt-1">{getDisplayUrl(link.url, link.kind)}</p>
        ))
      }
    </div>
  </div>
</header>
