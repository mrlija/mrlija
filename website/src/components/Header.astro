---
import { CV_DATA } from "../data/cv";
import LinkedIn from "./icons/LinkedIn.astro";
import GitHub from "./icons/GitHub.astro";
import Email from "./icons/Email.astro";
import Globe from "./icons/Globe.astro";

import { Image } from "astro:assets";
import avatarImage from "../assets/avatar.jpeg";

const { name, personalWebsiteUrl, contact, location, locationLink } = CV_DATA;
---

<header class="w-full lg:sticky lg:top-8 lg:self-start">
  <div class="rail-panel w-full overflow-hidden lg:mx-auto lg:max-w-xs">
    <div class="flex flex-col items-center p-5 text-center sm:p-6">
      <div class="flex w-full max-w-[13rem] flex-col items-center">
        <span
          class="relative flex aspect-square w-full shrink-0 overflow-hidden border border-border bg-secondary"
          style="border-radius: 12px"
          aria-hidden="true"
        >
          <Image
            class="aspect-square h-full w-full object-cover"
            alt={`${name}'s profile picture`}
            src={avatarImage}
          />
        </span>
        <div class="mt-4 w-full min-w-0">
          <h1
            class="text-3xl font-semibold tracking-tight text-foreground"
            id="cv-name"
          >
            {name}
          </h1>
          <a
            class="mt-3 inline-flex items-center justify-center gap-2 text-sm text-muted-foreground transition-colors duration-150 ease-out hover:text-foreground"
            href={locationLink}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Location: ${location}`}
          >
            <span>{location}</span>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-border">
      <a
        class="contact-link"
        href={personalWebsiteUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <Globe class="size-4" />
        <span class="min-w-0 truncate"
          >{personalWebsiteUrl.replace("https://", "")}</span
        >
      </a>
      <a class="contact-link" href={`mailto:${contact.email}`}>
        <Email class="size-4" />
        <span class="min-w-0 truncate">{contact.email}</span>
      </a>
      <a
        class="contact-link"
        href={contact.social[0].url}
        target="_blank"
        rel="noopener noreferrer"
      >
        <GitHub class="size-4" />
        <span class="min-w-0 truncate"
          >{contact.social[0].url.replace("https://", "")}</span
        >
      </a>
      <a
        class="contact-link"
        href={contact.social[1].url}
        target="_blank"
        rel="noopener noreferrer"
      >
        <LinkedIn class="size-4" />
        <span class="min-w-0 truncate"
          >{contact.social[1].url.replace("https://", "")}</span
        >
      </a>
    </div>

    <div
      class="hidden border-t border-border p-5 text-sm text-muted-foreground"
    >
      <p>{personalWebsiteUrl}</p>
      <p class="mt-1">{contact.email}</p>
      <p class="mt-1">{contact.social[0].url}</p>
      <p class="mt-1">{contact.social[1].url}</p>
    </div>
  </div>
</header>
