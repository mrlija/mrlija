---
import { Image } from "astro:assets";
import { CV_DATA } from "../data/cv";
import avatarImage from "../assets/avatar.jpeg";
import Summary from "./Summary.astro";
import WorkExperience from "./WorkExperience.astro";
import Projects from "./Projects.astro";
import Education from "./Education.astro";
import Skills from "./Skills.astro";

const { name, about, contact, location, locationLink } = CV_DATA;
const websiteLink = contact.links.find((link) => link.kind === "website");
const emailLink = contact.links.find((link) => link.kind === "email");
---

<main class="print-resume hidden print:block" id="print-content">
  <section
    class="mx-auto w-full max-w-2xl bg-white"
    aria-label="Obsah životopisu pro tisk"
  >
    <header class="flex items-start justify-between gap-6">
      <div class="flex-1 space-y-1">
        <h1
          class="text-3xl font-semibold tracking-tight text-foreground"
          id="cv-name-print"
        >
          {name}
        </h1>
        <p class="max-w-md text-pretty text-sm leading-5 text-muted-foreground">
          {about}
        </p>
        <p
          class="max-w-md items-center text-pretty text-sm leading-5 text-muted-foreground"
        >
          <a
            class="inline-flex gap-x-1.5 align-baseline leading-5 hover:underline"
            href={locationLink}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Lokace: ${location}`}
          >
            <span>{location}</span>
          </a>
        </p>
        <div
          class="hidden gap-x-2 gap-y-0.5 text-sm leading-5 text-muted-foreground print:flex print:flex-wrap"
        >
          {
            websiteLink && (
              <a
                class="underline hover:text-foreground/70"
                href={websiteLink.url}
              >
                {websiteLink.url}
              </a>
            )
          }
          {websiteLink && emailLink && <span aria-hidden="true">|</span>}
          {
            emailLink && (
              <a
                class="underline hover:text-foreground/70"
                href={emailLink.url}
              >
                {emailLink.url.replace("mailto:", "")}
              </a>
            )
          }
        </div>
      </div>
      <span
        class="relative mt-0.5 flex size-28 shrink-0 self-start overflow-hidden rounded-xl"
        aria-hidden="true"
      >
        <Image
          class="aspect-square h-full w-full"
          alt={`${name}'s profile picture`}
          src={avatarImage}
        />
      </span>
    </header>

    <div class="mt-5">
      <Summary />
      <WorkExperience />
      <Projects />
      <Education />
      <Skills />
    </div>
  </section>
</main>
