---
import { CV_DATA } from "../data/cv";

const { contact } = CV_DATA;
---

<div
  id="command-menu-banner"
  class="fixed bottom-4 right-4 z-40 hidden cursor-pointer border border-border bg-card px-3 py-2 text-sm text-muted-foreground transition-colors duration-150 ease-out hover:bg-accent hover:text-foreground md:block"
  style="border-radius: 10px"
  role="button"
  tabindex="0"
  aria-label="Otevřít příkazové menu"
>
  <div class="flex items-center gap-2">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
    <span class="hidden sm:inline">Menu</span>
    <kbd
      class="border border-border bg-secondary px-2 py-0.5 text-xs text-foreground"
      style="border-radius: 6px"
    >
      <span id="command-menu-shortcut">⌘ + K</span>
    </kbd>
  </div>
</div>

<div id="command-menu" class="fixed inset-0 z-50 hidden">
  <div class="fixed inset-0 bg-black/60" id="command-menu-backdrop"></div>
  <div class="fixed inset-0 flex items-start justify-center pt-[20vh]">
    <div
      class="relative mx-4 w-full max-w-2xl border border-border bg-card"
      style="border-radius: 12px"
      id="command-menu-content"
      role="dialog"
      aria-modal="true"
      aria-labelledby="command-menu-title"
    >
      <h2 id="command-menu-title" class="sr-only">Příkazové menu</h2>
      <div class="flex items-center border-b border-border px-4">
        <svg
          class="h-5 w-5 text-muted-foreground"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        <input
          type="text"
          id="command-menu-input"
          class="flex-1 border-0 bg-transparent px-4 py-4 text-foreground placeholder:text-muted-foreground outline-none"
          placeholder="Zadejte příkaz nebo hledejte..."
          autocomplete="off"
          role="combobox"
          aria-expanded="true"
          aria-controls="command-menu-list"
        />
        <kbd
          class="hidden border border-border bg-secondary px-2 py-1 text-xs text-foreground sm:inline-block"
          style="border-radius: 6px"
        >
          ESC
        </kbd>
      </div>

      <div
        class="max-h-[400px] overflow-y-auto p-2"
        id="command-menu-list"
        role="listbox"
      >
        <div class="command-group" data-group="navigation">
          <div class="px-2 py-1.5 text-xs font-medium text-muted-foreground">
            Navigace
          </div>
          <button
            class="command-item w-full px-3 py-2 text-left text-foreground hover:bg-accent"
            style="border-radius: 8px"
            data-action="scroll"
            data-target="about-section"
            data-shortcut-code="Digit1"
            role="option"
            aria-keyshortcuts="1"
          >
            <div class="flex items-center justify-between gap-3">
              <div class="flex items-center gap-3">
                <svg
                  class="h-4 w-4 text-muted-foreground"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                  ></path>
                </svg>
                <div class="text-sm font-medium text-foreground">O mně</div>
              </div>
              <kbd
                class="command-item-shortcut hidden border border-border bg-secondary px-2 py-0.5 text-xs text-muted-foreground sm:inline-flex"
                style="border-radius: 6px"
              >
                1
              </kbd>
            </div>
          </button>
          <button
            class="command-item w-full px-3 py-2 text-left text-foreground hover:bg-accent"
            style="border-radius: 8px"
            data-action="scroll"
            data-target="work-experience"
            data-shortcut-code="Digit2"
            role="option"
            aria-keyshortcuts="2"
          >
            <div class="flex items-center justify-between gap-3">
              <div class="flex items-center gap-3">
                <svg
                  class="h-4 w-4 text-muted-foreground"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
                <div class="text-sm font-medium text-foreground">
                  Pracovní zkušenosti
                </div>
              </div>
              <kbd
                class="command-item-shortcut hidden border border-border bg-secondary px-2 py-0.5 text-xs text-muted-foreground sm:inline-flex"
                style="border-radius: 6px"
              >
                2
              </kbd>
            </div>
          </button>
          <button
            class="command-item w-full px-3 py-2 text-left text-foreground hover:bg-accent"
            style="border-radius: 8px"
            data-action="scroll"
            data-target="projects"
            data-shortcut-code="Digit3"
            role="option"
            aria-keyshortcuts="3"
          >
            <div class="flex items-center justify-between gap-3">
              <div class="flex items-center gap-3">
                <svg
                  class="h-4 w-4 text-muted-foreground"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"
                  ></path>
                </svg>
                <div class="text-sm font-medium text-foreground">Projekty</div>
              </div>
              <kbd
                class="command-item-shortcut hidden border border-border bg-secondary px-2 py-0.5 text-xs text-muted-foreground sm:inline-flex"
                style="border-radius: 6px"
              >
                3
              </kbd>
            </div>
          </button>
          <button
            class="command-item w-full px-3 py-2 text-left text-foreground hover:bg-accent"
            style="border-radius: 8px"
            data-action="scroll"
            data-target="education-section"
            data-shortcut-code="Digit4"
            role="option"
            aria-keyshortcuts="4"
          >
            <div class="flex items-center justify-between gap-3">
              <div class="flex items-center gap-3">
                <svg
                  class="h-4 w-4 text-muted-foreground"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 14l9-5-9-5-9 5 9 5z"></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
                  ></path>
                </svg>
                <div class="text-sm font-medium text-foreground">Vzdělání</div>
              </div>
              <kbd
                class="command-item-shortcut hidden border border-border bg-secondary px-2 py-0.5 text-xs text-muted-foreground sm:inline-flex"
                style="border-radius: 6px"
              >
                4
              </kbd>
            </div>
          </button>
          <button
            class="command-item w-full px-3 py-2 text-left text-foreground hover:bg-accent"
            style="border-radius: 8px"
            data-action="scroll"
            data-target="skills-section"
            data-shortcut-code="Digit5"
            role="option"
            aria-keyshortcuts="5"
          >
            <div class="flex items-center justify-between gap-3">
              <div class="flex items-center gap-3">
                <svg
                  class="h-4 w-4 text-muted-foreground"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
                  ></path>
                </svg>
                <div class="text-sm font-medium text-foreground">
                  Dovednosti
                </div>
              </div>
              <kbd
                class="command-item-shortcut hidden border border-border bg-secondary px-2 py-0.5 text-xs text-muted-foreground sm:inline-flex"
                style="border-radius: 6px"
              >
                5
              </kbd>
            </div>
          </button>
        </div>

        <div class="command-group mt-2" data-group="actions">
          <div class="px-2 py-1.5 text-xs font-medium text-muted-foreground">
            Akce
          </div>
          <button
            class="command-item w-full px-3 py-2 text-left text-foreground hover:bg-accent"
            style="border-radius: 8px"
            data-action="mailto"
            data-email={contact.email}
            data-shortcut-code="Digit6"
            role="option"
            aria-keyshortcuts="6"
          >
            <div class="flex items-center justify-between gap-3">
              <div class="flex items-center gap-3">
                <svg
                  class="h-4 w-4 text-muted-foreground"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
                <div class="text-sm font-medium text-foreground">
                  Poslat email
                </div>
              </div>
              <kbd
                class="command-item-shortcut hidden border border-border bg-secondary px-2 py-0.5 text-xs text-muted-foreground sm:inline-flex"
                style="border-radius: 6px"
              >
                6
              </kbd>
            </div>
          </button>
          <button
            class="command-item w-full px-3 py-2 text-left text-foreground hover:bg-accent"
            style="border-radius: 8px"
            data-action="print"
            data-shortcut-code="Digit7"
            role="option"
            aria-keyshortcuts="7"
          >
            <div class="flex items-center justify-between gap-3">
              <div class="flex items-center gap-3">
                <svg
                  class="h-4 w-4 text-muted-foreground"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"
                  ></path>
                </svg>
                <div class="text-sm font-medium text-foreground">
                  Vytisknout životopis
                </div>
              </div>
              <kbd
                class="command-item-shortcut hidden border border-border bg-secondary px-2 py-0.5 text-xs text-muted-foreground sm:inline-flex"
                style="border-radius: 6px"
              >
                7
              </kbd>
            </div>
          </button>
        </div>

        <div
          id="command-menu-empty-state"
          class="hidden px-4 py-8 text-center text-sm text-muted-foreground"
        >
          Žádné výsledky.
        </div>

        <div class="mt-4 border-t border-border px-2 pb-1.5 pt-3">
          <div
            class="flex items-center justify-between px-2 text-xs text-muted-foreground"
          >
            <div class="flex gap-4">
              <span class="flex items-center gap-1">
                <kbd
                  class="inline-flex h-5 items-center justify-center border border-border bg-secondary px-1.5 leading-none"
                  style="border-radius: 6px">↑↓</kbd
                >
                navigace
              </span>
              <span class="flex items-center gap-1">
                <kbd
                  class="inline-flex h-5 items-center justify-center border border-border bg-secondary px-1.5 leading-none"
                  style="border-radius: 6px">↵</kbd
                >
                vybrat
              </span>
            </div>
            <span class="flex items-center gap-1">
              <kbd
                class="inline-flex h-5 items-center justify-center border border-border bg-secondary px-1.5 leading-none"
                style="border-radius: 6px">ESC</kbd
              >
              zavřít
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const desktopViewport = window.matchMedia("(min-width: 768px)");

  class CommandMenu {
    private menu: HTMLElement;
    private backdrop: HTMLElement;
    private content: HTMLElement;
    private banner: HTMLElement;
    private input: HTMLInputElement;
    private emptyState: HTMLElement;
    private items: NodeListOf<HTMLElement>;
    private selectedIndex: number = 0;
    private isOpen: boolean = false;
    private previousFocus: HTMLElement | null = null;

    constructor() {
      this.menu = document.getElementById("command-menu")!;
      this.backdrop = document.getElementById("command-menu-backdrop")!;
      this.content = document.getElementById("command-menu-content")!;
      this.banner = document.getElementById("command-menu-banner")!;
      this.input = document.getElementById(
        "command-menu-input",
      )! as HTMLInputElement;
      this.emptyState = document.getElementById("command-menu-empty-state")!;
      this.items = document.querySelectorAll(".command-item");

      this.init();
    }

    private init() {
      this.banner.addEventListener("click", () => {
        this.open();
      });

      this.banner.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          this.open();
        }
      });

      document.addEventListener("keydown", (e) => {
        if (!desktopViewport.matches) {
          return;
        }

        if ((e.metaKey || e.ctrlKey) && e.key === "k") {
          e.preventDefault();
          this.toggle();
        }

        if (e.key === "Escape" && this.isOpen) {
          this.close();
        }

        if (this.isOpen && e.key === "Tab") {
          this.trapFocus(e);
          return;
        }

        if (this.isOpen && this.handleItemShortcut(e)) {
          return;
        }

        if (this.isOpen) {
          if (e.key === "ArrowDown") {
            e.preventDefault();
            this.selectNext();
          } else if (e.key === "ArrowUp") {
            e.preventDefault();
            this.selectPrevious();
          } else if (e.key === "Enter") {
            e.preventDefault();
            this.executeSelected();
          }
        }
      });

      this.backdrop.addEventListener("click", () => this.close());

      this.menu.addEventListener("click", (event) => {
        if (!this.isOpen) return;

        const target = event.target;
        if (!(target instanceof Node)) return;

        if (!this.content.contains(target)) {
          this.close();
        }
      });

      this.input.addEventListener("input", (e) => {
        this.filterItems((e.target as HTMLInputElement).value);
      });

      this.items.forEach((item) => {
        item.addEventListener("click", () => {
          this.executeAction(item);
        });

        item.addEventListener("mouseenter", () => {
          this.items.forEach((i) => i.classList.remove("bg-accent"));
          item.classList.add("bg-accent");
          this.selectedIndex = Array.from(this.items).indexOf(item);
        });
      });

      desktopViewport.addEventListener("change", (event) => {
        if (!event.matches && this.isOpen) {
          this.close();
        }
      });
    }

    private toggle() {
      if (!desktopViewport.matches) {
        return;
      }

      if (this.isOpen) {
        this.close();
      } else {
        this.open();
      }
    }

    private open() {
      if (!desktopViewport.matches) {
        return;
      }

      this.previousFocus =
        document.activeElement instanceof HTMLElement
          ? document.activeElement
          : null;
      this.isOpen = true;
      this.menu.classList.remove("hidden");
      this.input.value = "";
      this.filterItems("");
      this.input.focus();
      this.selectedIndex = 0;
      this.updateSelection();
      document.body.style.overflow = "hidden";
    }

    private close() {
      this.isOpen = false;
      this.menu.classList.add("hidden");
      document.body.style.overflow = "";
      this.previousFocus?.focus();
    }

    private selectNext() {
      const visibleItems = this.getVisibleItems();
      if (visibleItems.length === 0) return;

      this.selectedIndex = (this.selectedIndex + 1) % visibleItems.length;
      this.updateSelection();
    }

    private selectPrevious() {
      const visibleItems = this.getVisibleItems();
      if (visibleItems.length === 0) return;

      this.selectedIndex =
        this.selectedIndex - 1 < 0
          ? visibleItems.length - 1
          : this.selectedIndex - 1;
      this.updateSelection();
    }

    private getVisibleItems(): HTMLElement[] {
      return Array.from(this.items).filter(
        (item) => !item.classList.contains("hidden"),
      );
    }

    private updateSelection() {
      const visibleItems = this.getVisibleItems();
      this.items.forEach((item) => item.classList.remove("bg-accent"));

      if (visibleItems[this.selectedIndex]) {
        visibleItems[this.selectedIndex].classList.add("bg-accent");
        visibleItems[this.selectedIndex].scrollIntoView({
          block: "nearest",
          behavior: "smooth",
        });
      }
    }

    private executeSelected() {
      const visibleItems = this.getVisibleItems();
      const selectedItem = visibleItems[this.selectedIndex];
      if (selectedItem) {
        this.executeAction(selectedItem);
      }
    }

    private handleItemShortcut(event: KeyboardEvent): boolean {
      if (
        this.input.value.trim().length > 0 ||
        event.metaKey ||
        event.ctrlKey ||
        event.altKey ||
        event.shiftKey ||
        event.repeat
      ) {
        return false;
      }

      const shortcutItem = this.getVisibleItems().find(
        (item) => item.dataset.shortcutCode === event.code,
      );

      if (!shortcutItem) {
        return false;
      }

      event.preventDefault();
      this.executeAction(shortcutItem);
      return true;
    }

    private trapFocus(event: KeyboardEvent) {
      const focusableElements = Array.from(
        this.content.querySelectorAll<HTMLElement>(
          'button:not([disabled]), input:not([disabled]), [href], [tabindex]:not([tabindex="-1"])',
        ),
      ).filter((element) => !element.classList.contains("hidden"));

      if (focusableElements.length === 0) {
        return;
      }

      const firstElement = focusableElements[0];
      const lastElement = focusableElements[focusableElements.length - 1];
      const activeElement = document.activeElement;

      if (event.shiftKey && activeElement === firstElement) {
        event.preventDefault();
        lastElement.focus();
        return;
      }

      if (!event.shiftKey && activeElement === lastElement) {
        event.preventDefault();
        firstElement.focus();
      }
    }

    private executeAction(item: HTMLElement) {
      const action = item.dataset.action;

      switch (action) {
        case "scroll":
          const target = item.dataset.target;
          if (target) {
            this.scrollToSection(target);
          }
          this.close();
          break;
        case "print":
          this.close();
          setTimeout(() => {
            window.print();
          }, 100);
          break;
        case "mailto":
          const email = item.dataset.email;
          if (email) {
            window.location.href = `mailto:${email}`;
          }
          this.close();
          break;
      }
    }

    private scrollToSection(sectionId: string) {
      const section = document.getElementById(sectionId);
      if (section) {
        section.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }

    private filterItems(query: string) {
      const searchQuery = query.toLowerCase().trim();

      if (!searchQuery) {
        this.items.forEach((item) => item.classList.remove("hidden"));
        document
          .querySelectorAll(".command-group")
          .forEach((group) => group.classList.remove("hidden"));
        this.emptyState.classList.add("hidden");
        this.selectedIndex = 0;
        this.updateSelection();
        return;
      }

      const groups = new Map<string, boolean>();

      this.items.forEach((item) => {
        const text = item.textContent?.toLowerCase() || "";
        if (text.includes(searchQuery)) {
          item.classList.remove("hidden");
          const group = item.closest(".command-group") as HTMLElement;
          if (group) {
            groups.set(group.dataset.group || "", true);
          }
        } else {
          item.classList.add("hidden");
        }
      });

      document.querySelectorAll(".command-group").forEach((group) => {
        const groupElement = group as HTMLElement;
        const groupName = groupElement.dataset.group || "";
        if (groups.has(groupName)) {
          groupElement.classList.remove("hidden");
        } else {
          groupElement.classList.add("hidden");
        }
      });

      this.emptyState.classList.toggle(
        "hidden",
        this.getVisibleItems().length > 0,
      );

      this.selectedIndex = 0;
      this.updateSelection();
    }
  }

  new CommandMenu();

  const shortcutLabel = document.getElementById("command-menu-shortcut");
  const commandItemShortcuts = document.querySelectorAll(
    ".command-item-shortcut",
  );
  const userAgentData = (
    navigator as Navigator & { userAgentData?: { platform?: string } }
  ).userAgentData;
  const platformInfo = userAgentData?.platform ?? navigator.userAgent;
  const isMac = /mac/i.test(platformInfo);

  const formatShortcutLabel = (shortcutCode: string) => {
    return shortcutCode.startsWith("Digit")
      ? shortcutCode.replace("Digit", "")
      : shortcutCode.replace("Key", "");
  };

  if (shortcutLabel) {
    shortcutLabel.textContent = isMac ? "⌘ + K" : "Ctrl + K";
  }

  commandItemShortcuts.forEach((shortcutElement) => {
    const item = shortcutElement.closest(".command-item") as HTMLElement | null;
    const shortcutCode = item?.dataset.shortcutCode;

    if (!shortcutCode) {
      return;
    }

    shortcutElement.textContent = formatShortcutLabel(shortcutCode);
  });
</script>
