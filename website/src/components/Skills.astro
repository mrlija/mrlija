---
import { CV_DATA } from "../data/cv";
import Badge from "./common/Badge.astro";

const { skills } = CV_DATA;
---

<section class="section-block print-keep-together">
  <h2 class="section-heading" id="skills-section">Dovednosti</h2>
  <ul
    class="mb-2 mt-2 flex list-none flex-wrap gap-2 p-0"
    aria-label="Seznam dovedností"
  >
    {
      skills.map((skill) => (
        <li>
          <Badge variant="primary">{skill}</Badge>
        </li>
      ))
    }
  </ul>
</section>
